generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  tags        String?
  coverUrl    String?

  platform    String   @default("抖音")
  aspectRatio String   @default("9:16")
  resolution  String   @default("1080x1920")
  duration    String   @default("60s")

  stylePreset     String?
  globalNegPrompt String?
  styleRefUrl     String?

  status    String   @default("draft")
  step      Int      @default(1)
  stepLabel String   @default("小说导入")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
