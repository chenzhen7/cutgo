generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  tags        String?
  coverUrl    String?

  platform    String   @default("抖音")
  aspectRatio String   @default("9:16")
  resolution  String   @default("1080x1920")
  duration    String   @default("60s")

  stylePreset     String?
  globalNegPrompt String?
  styleRefUrl     String?

  status    String   @default("draft")
  step      Int      @default(1)
  stepLabel String   @default("小说导入")

  novel    Novel?
  episodes Episode[]
  scripts  Script[]
  storyboards Storyboard[]

  assetCharacters AssetCharacter[]
  assetScenes     AssetScene[]
  assetProps      AssetProp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Novel {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title     String?
  rawText   String
  wordCount Int
  source    String  @default("paste") // "paste" | "file"
  fileName  String?

  synopsis String? // AI 生成的故事大纲

  status String @default("draft") // "draft" | "analyzed" | "confirmed"

  chapters   Chapter[]
  characters NovelCharacter[]
  events     PlotEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chapter {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  index     Int
  title     String?
  content   String
  wordCount Int
  selected  Boolean @default(true)

  paragraphs Paragraph[]
  episodes   Episode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paragraph {
  id        String  @id @default(cuid())
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  index     Int
  content   String
  wordCount Int
  selected  Boolean @default(true)

  createdAt DateTime @default(now())
}

model NovelCharacter {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  name        String
  role        String  @default("supporting") // "protagonist" | "supporting" | "extra"
  description String?
  firstAppear String?
  frequency   Int     @default(1)
  relations   String? // JSON: [{ target: "角色B", relation: "恋人" }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlotEvent {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  index       Int
  type        String  // "setup" | "rising" | "climax" | "resolution"
  summary     String
  detail      String?
  emotion     String?
  sourceRef   String?
  adaptScore  Int?
  isHighlight Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Episode {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  index       Int
  title       String
  synopsis    String
  keyConflict String?
  cliffhanger String?
  duration    String  @default("60s")

  scenes EpisodeScene[]
  script Script?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EpisodeScene {
  id        String  @id @default(cuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  index      Int
  title      String
  summary    String
  duration   String  @default("15s")
  characters String?
  emotion    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Script {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  episodeId String  @unique
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  title      String
  content    String    @default("")
  status     String    @default("draft") // "draft" | "generated" | "edited"
  characters String?   // JSON array of asset character names
  props      String?   // JSON array of asset prop names
  location   String?   // asset scene name

  storyboards Storyboard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Asset Models ──

model AssetCharacter {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  role        String  @default("supporting") // "protagonist" | "supporting" | "extra"
  gender      String? // "male" | "female" | "other"
  age         String?
  description String?
  appearance  String?
  personality String?
  imageUrl    String?
  seed        Int?
  locked      Boolean @default(false)

  sourceNovelCharacterId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

model AssetScene {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  description String?
  imageUrl    String?
  tags        String?
  timeOfDay   String?
  weather     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

model AssetProp {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name        String
  description String?
  imageUrl    String?
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

// ── Storyboard Models ──

model Storyboard {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  status String @default("draft") // "draft" | "generated" | "edited"

  shots Shot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Shot {
  id           String     @id @default(cuid())
  storyboardId String
  storyboard   Storyboard @relation(fields: [storyboardId], references: [id], onDelete: Cascade)

  index           Int
  shotSize        String
  cameraMovement  String    @default("static")
  cameraAngle     String    @default("eye_level")
  composition     String
  prompt          String
  negativePrompt  String?
  duration        String    @default("3s")
  imageUrl        String?
  imageType       String    @default("keyframe") // "keyframe" | "first_last" | "multi_grid"
  imageUrls       String?   // JSON: first_last mode ["url1", "url2"]
  promptEnd       String?   // first_last mode: end-frame prompt
  gridLayout      String?   // multi_grid layout: "2x2" | "1x3" | "2x3"
  gridPrompts     String?   // JSON: multi_grid per-cell prompts ["p1","p2",...]

  videoUrl        String?   // AI 生成的视频片段 URL
  videoStatus     String    @default("pending") // "pending" | "generating" | "completed" | "failed"
  videoPrompt     String?   // 视频生成专用提示词 (如果与图片不同)
  videoDuration   Float?    // 实际生成的视频时长

  scriptLineIds   String?
  dialogueText    String?
  actionNote      String?

  characterIds    String?   // JSON array of AssetCharacter IDs
  sceneId         String?   // AssetScene ID
  propIds         String?   // JSON array of AssetProp IDs

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
