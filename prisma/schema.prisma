generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// 短视频/漫剧项目主表
model Project {
  /// 主键
  id          String  @id @default(cuid())
  /// 项目名称
  name        String
  /// 项目描述
  description String?
  /// 标签（可存逗号分隔或 JSON，视业务而定）
  tags        String?
  /// 封面图 URL
  coverUrl    String?

  /// 画幅比，如 9:16
  aspectRatio String @default("9:16")
  /// 分辨率描述，如 1080x1920
  resolution  String @default("1080x1920")

  /// 视觉风格名称（中文；预设与 STYLE_PRESETS.label 一致，自定义则为用户文案）
  stylePreset     String?
  /// 全局负面提示词（图像等）
  globalNegPrompt String?
  /// 风格参考图 URL
  styleRefUrl     String?

  /// 项目状态，如 draft
  status String @default("draft")

  episodes Episode[]

  assetCharacters   AssetCharacter[]
  assetScenes       AssetScene[]
  assetProps        AssetProp[]
  videoCompositions VideoComposition[]
  // aiTasks           AiTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 分集
model Episode {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 本集小说原文
  rawText   String?
  /// 原文字数（冗余存储）
  wordCount Int?

  /// 集序号
  index       Int
  /// 分集标题
  title       String
  /// 本集目标时长描述
  duration    String  @default("60s")

  /// 剧本正文（不为空说明该分集存在剧本）
  script String @default("")

  /// 默认镜头类型（keyframe | first_last | multi_grid）
  shotType String @default("keyframe")

  shots             Shot[]
  videoCompositions VideoComposition[]
  episodeAssets     EpisodeAsset[]
  // aiTasks           AiTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Asset Models ──

/// 项目级角色资产（立绘、设定）
model AssetCharacter {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 角色名称（项目内唯一）
  name        String
  /// protagonist | supporting | extra
  role        String  @default("supporting")
  /// male | female | other
  gender      String?
  /// 角色生图提示词
  prompt      String?
  /// 立绘/参考图 URL
  imageUrl    String?
  /// idle | generating | completed | error
  imageStatus String  @default("idle")
  /// 图片生成异步任务 ID（用于轮询进度）
  imageTaskId String?
  imageErrorMessage String?
  /// 图像生成随机种子（可空）
  seed        Int?
  /// 是否锁定不再自动改写
  locked      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

/// 项目级场景资产
model AssetScene {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 场景名称（项目内唯一）
  name        String
  /// 场景提示词
  prompt      String?
  imageUrl    String?
  /// idle | generating | completed | error
  imageStatus String  @default("idle")
  /// 图片生成异步任务 ID（用于轮询进度）
  imageTaskId String?
  imageErrorMessage String?
  /// 标签
  tags        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

/// 项目级道具资产
model AssetProp {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 道具名称（项目内唯一）
  name        String
  /// 道具提示词
  prompt      String?
  imageUrl    String?
  /// idle | generating | completed | error
  imageStatus String  @default("idle")
  /// 图片生成异步任务 ID（用于轮询进度）
  imageTaskId String?
  imageErrorMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

/// 分集视频合成任务与输出
model VideoComposition {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  /// JSON：VideoCompositionConfig
  config String

  /// idle | preparing | tts_generating | subtitle_generating | compositing | completed | error
  status String @default("idle")

  /// 输出文件路径
  outputPath    String?
  /// 文件大小（字节）
  fileSize      Int?
  /// 成片时长（秒）
  videoDuration Float?
  /// 版本号（重跑递增）
  version       Int     @default(1)

  errorMessage String?
  /// 进度 0–100
  progress     Int     @default(0)
  /// 当前子步骤说明
  currentStep  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // aiTasks   AiTask[]
}

/// 分镜镜头
model Shot {
  id        String  @id @default(cuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  /// 镜头序号
  index          Int
  /// 分镜内容描述（剧情和画面意图）
  content        String?
  /// 分镜提示词（用于生图）
  prompt         String
  negativePrompt String?
  /// 镜头时长
  duration       Float  @default(3)
  imageUrl       String?
  /// idle | generating | completed | error
  imageStatus    String @default("idle")
  /// 图片生成异步任务 ID（用于轮询进度）
  imageTaskId    String?
  imageErrorMessage String?
  /// keyframe | first_last | multi_grid
  imageType      String  @default("keyframe")
  /// first_last：首尾帧 URL 的 JSON 数组
  imageUrls      String?
  /// first_last：尾帧提示词
  promptEnd      String?
  /// multi_grid：布局如 2x2、1x3
  gridLayout     String?
  /// multi_grid：每格提示词 JSON 数组
  gridPrompts    String?

  scriptLineIds String?
  dialogueText  String?
  actionNote    String?

  shotAssets ShotAsset[]

  videoUrl      String?
  /// idle | generating | completed | error
  videoStatus   String?
  videoPrompt   String?
  videoDuration Float?
  /// 视频生成异步任务 ID（用于轮询进度）
  videoTaskId   String?
  /// 片段音量（0-200%）
  volume        Float   @default(100)
  /// 播放速度（0.25x-4x）
  speed         Float   @default(1)

  /// 用户自定义参考图 URL 列表 JSON
  refImageUrls String?
  /// 用户自定义参考图说明
  refImageNote String?

  /// 历史图片记录 JSON [{url, imageUrls, imageType, createdAt}]
  imageHistory String?
  /// 历史视频记录 JSON [{url, videoDuration, createdAt}]
  videoHistory String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // aiTasks   AiTask[]
}

/// 分集资产关联表（替代 Episode.characters/scenes/props JSON 字段）
model EpisodeAsset {
  id        String  @id @default(cuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  /// character | scene | prop
  assetType String
  assetId   String

  createdAt DateTime @default(now())

  @@unique([episodeId, assetType, assetId])
  @@index([episodeId])
}

/// 分镜资产关联表（替代 Shot.characterIds/sceneId/propIds JSON 字段）
model ShotAsset {
  id     String @id @default(cuid())
  shotId String
  shot   Shot   @relation(fields: [shotId], references: [id], onDelete: Cascade)

  /// character | scene | prop
  assetType String
  assetId   String

  createdAt DateTime @default(now())

  @@unique([shotId, assetType, assetId])
  @@index([shotId])
}

/// 统一 AI 任务中心（跨 LLM / Image / Video / TTS）
model AiTask {
  id String @id @default(cuid())

  projectId          String
  episodeId          String?
  shotId             String?
  videoCompositionId String?

  /// 目标对象快照，如【项目 XXX】【第1集 XXXXX】【分镜 1】等
  targetInfo String @default("")

  /// llm_script | llm_shot | image_generate | shot_video_generate | video_generate | tts_generate
  taskType String
  /// queued | running | succeeded | failed | cancelled
  status   String @default("queued")

  /// 执行时模型快照，如 openai/gpt-4o
  model String?

  errorCode    String?
  errorMessage String?

  retryCount Int @default(0)
  maxRetries Int @default(0)

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([projectId, createdAt])
  @@index([status, updatedAt])
  @@index([taskType, status])
}

// ── AI 配置（Settings 为全局单条，id 默认 global）──

/// 可多条：各类 AI 模型连接配置
model AIModelConfig {
  id       String @id @default(cuid())
  /// 展示名称，如「我的 GPT-4o」
  name     String
  /// llm | image | video | tts
  type     String
  /// openai | deepseek | comfyui 等
  provider String
  /// 模型 id，如 gpt-4o
  model    String
  apiKey   String @default("")
  baseUrl  String @default("")
  /// JSON 扩展参数（如 ComfyUI 工作流相关）
  config   String @default("{}")

  /// 是否为该 type 下的默认配置
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

/// 全局设置（单行，主键常为 global）
model Settings {
  id String @id @default("global")

  /// 当前选用的 LLM 配置 id
  activeLLMConfigId   String?
  /// 当前选用的图像配置 id
  activeImageConfigId String?
  /// 当前选用的视频配置 id
  activeVideoConfigId String?
  /// 当前选用的 TTS 配置 id
  activeTTSConfigId   String?

  /// 旧版：文本模型提供商
  textProvider String @default("deepseek")
  /// 旧版：文本模型名
  textModel    String @default("deepseek-v3")
  textApiKey   String @default("")
  textBaseUrl  String @default("")

  /// 旧版：图像提供商
  imageProvider String @default("placeholder")
  imageModel    String @default("dall-e-3")
  imageApiKey   String @default("")
  imageBaseUrl  String @default("")
  comfyuiUrl    String @default("http://127.0.0.1:8188")

  /// 旧版：视频提供商
  videoProvider String @default("placeholder")
  videoModel    String @default("")
  videoApiKey   String @default("")
  videoBaseUrl  String @default("")

  /// 旧版：TTS 提供商
  ttsProvider String @default("edge-tts")
  ttsModel    String @default("")
  ttsApiKey   String @default("")
  ttsBaseUrl  String @default("")

  updatedAt DateTime @updatedAt
}
