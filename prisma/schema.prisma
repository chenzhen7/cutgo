generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// 短视频/漫剧项目主表
model Project {
  /// 主键
  id          String  @id @default(cuid())
  /// 项目名称
  name        String
  /// 项目描述
  description String?
  /// 标签（可存逗号分隔或 JSON，视业务而定）
  tags        String?
  /// 封面图 URL
  coverUrl    String?

  /// 目标发布平台，如「抖音」
  platform    String @default("抖音")
  /// 画幅比，如 9:16
  aspectRatio String @default("9:16")
  /// 分辨率描述，如 1080x1920
  resolution  String @default("1080x1920")
  /// 目标单集时长描述，如 60s
  duration    String @default("60s")

  /// 风格预设标识或名称
  stylePreset     String?
  /// 全局负面提示词（图像等）
  globalNegPrompt String?
  /// 风格参考图 URL
  styleRefUrl     String?

  /// 项目状态，如 draft
  status    String @default("draft")
  /// 当前流程步骤序号（1-based）
  step      Int    @default(1)
  /// 当前步骤展示文案，如「小说导入」
  stepLabel String @default("小说导入")

  novel    Novel?
  episodes Episode[]

  assetCharacters   AssetCharacter[]
  assetScenes       AssetScene[]
  assetProps        AssetProp[]
  videoCompositions VideoComposition[]
  // aiTasks           AiTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 项目关联的小说原文与分析产物
model Novel {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 小说标题（可空）
  title     String?
  /// 原始全文
  rawText   String
  /// 字数统计
  wordCount Int

  chapters Chapter[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 小说章节
model Chapter {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  /// 章节序号（从 0 或 1 起，与业务一致）
  index     Int
  /// 章节标题
  title     String?
  /// 章节正文
  content   String
  /// 本章字数
  wordCount Int
  /// 是否参与后续分集/选用
  selected  Boolean @default(true)

  paragraphs Paragraph[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// 章节内段落（细粒度选用）
model Paragraph {
  id        String  @id @default(cuid())
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  /// 段落在章内序号
  index     Int
  /// 段落文本
  content   String
  /// 段落字数
  wordCount Int
  /// 是否选用
  selected  Boolean @default(true)

  createdAt DateTime @default(now())
}

/// 分集
model Episode {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// JSON 字符串数组：本集涵盖的章节 ID（有序）；无关联章节时为 null
  chapterIds String?

  /// 集序号
  index       Int
  /// 分集标题
  title       String
  /// 分集大纲（纯文本）
  outline     String?
  /// 黄金钩子/开场吸引点
  goldenHook  String?
  /// 核心冲突
  keyConflict String?
  /// 悬念/钩子等收尾
  cliffhanger String?
  /// 本集目标时长描述
  duration    String  @default("60s")

  /// JSON 字符串数组：本集涉及的角色资产id列表
  characters String?
  /// JSON 字符串数组：本集涉及的场景资产id列表
  scenes     String?
  /// JSON 字符串数组：本集涉及的道具资产id列表
  props      String?

  /// 剧本正文（不为空说明该分集存在剧本）
  script String @default("")

  shots             Shot[]
  videoCompositions VideoComposition[]
  // aiTasks           AiTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Asset Models ──

/// 项目级角色资产（立绘、设定）
model AssetCharacter {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 角色名称（项目内唯一）
  name        String
  /// protagonist | supporting | extra
  role        String  @default("supporting")
  /// male | female | other
  gender      String?
  /// 背景设定
  description String?
  /// 性格描述
  personality String?
  /// 立绘/参考图 URL
  imageUrl    String?
  /// 图像生成随机种子（可空）
  seed        Int?
  /// 是否锁定不再自动改写
  locked      Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

/// 项目级场景资产
model AssetScene {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 场景名称（项目内唯一）
  name        String
  /// 场景说明
  description String?
  imageUrl    String?
  /// 标签
  tags        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

/// 项目级道具资产
model AssetProp {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// 道具名称（项目内唯一）
  name        String
  description String?
  imageUrl    String?
  /// 分类
  category    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, name])
}

/// 分集视频合成任务与输出
model VideoComposition {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  /// JSON：VideoCompositionConfig
  config String

  /// idle | preparing | tts_generating | subtitle_generating | compositing | completed | error
  status String @default("idle")

  /// 输出文件路径
  outputPath    String?
  /// 文件大小（字节）
  fileSize      Int?
  /// 成片时长（秒）
  videoDuration Float?
  /// 版本号（重跑递增）
  version       Int     @default(1)

  errorMessage String?
  /// 进度 0–100
  progress     Int     @default(0)
  /// 当前子步骤说明
  currentStep  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // aiTasks   AiTask[]
}

/// 分镜镜头
model Shot {
  id        String  @id @default(cuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  /// 镜头序号
  index          Int
  /// 分镜提示词（用于生图）
  prompt         String
  negativePrompt String?
  /// 镜头时长
  duration       String  @default("3s")
  imageUrl       String?
  /// keyframe | first_last | multi_grid
  imageType      String  @default("keyframe")
  /// first_last：首尾帧 URL 的 JSON 数组
  imageUrls      String?
  /// first_last：尾帧提示词
  promptEnd      String?
  /// multi_grid：布局如 2x2、1x3
  gridLayout     String?
  /// multi_grid：每格提示词 JSON 数组
  gridPrompts    String?

  scriptLineIds String?
  dialogueText  String?
  actionNote    String?

  /// JSON：AssetCharacter id 数组
  characterIds String?
  /// AssetScene id
  sceneId      String?
  /// JSON：AssetProp id 数组
  propIds      String?

  videoUrl      String?
  /// idle | generating | completed | error
  videoStatus   String?
  videoPrompt   String?
  videoDuration String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // aiTasks   AiTask[]
}

/// 统一 AI 任务中心（跨 LLM / Image / Video / TTS）
model AiTask {
  id String @id @default(cuid())

  projectId          String
  episodeId          String?
  shotId             String?
  videoCompositionId String?

  /// 目标对象快照，如【项目 XXX】【第1集 XXXXX】【分镜 1】等
  targetInfo String @default("")

  /// llm_script | llm_shot | image_generate | shot_video_generate | video_generate | tts_generate
  taskType String
  /// queued | running | succeeded | failed | cancelled
  status   String @default("queued")

  /// 执行时模型快照，如 openai/gpt-4o
  model String?

  errorCode    String?
  errorMessage String?

  retryCount Int @default(0)
  maxRetries Int @default(0)

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([projectId, createdAt])
  @@index([status, updatedAt])
  @@index([taskType, status])
}

// ── AI 配置（Settings 为全局单条，id 默认 global）──

/// 可多条：各类 AI 模型连接配置
model AIModelConfig {
  id       String @id @default(cuid())
  /// 展示名称，如「我的 GPT-4o」
  name     String
  /// llm | image | video | tts
  type     String
  /// openai | deepseek | comfyui 等
  provider String
  /// 模型 id，如 gpt-4o
  model    String
  apiKey   String @default("")
  baseUrl  String @default("")
  /// JSON 扩展参数（如 ComfyUI 工作流相关）
  config   String @default("{}")

  /// 是否为该 type 下的默认配置
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

/// 全局设置（单行，主键常为 global）
model Settings {
  id String @id @default("global")

  /// 当前选用的 LLM 配置 id
  activeLLMConfigId   String?
  /// 当前选用的图像配置 id
  activeImageConfigId String?
  /// 当前选用的视频配置 id
  activeVideoConfigId String?
  /// 当前选用的 TTS 配置 id
  activeTTSConfigId   String?

  /// 旧版：文本模型提供商
  textProvider String @default("deepseek")
  /// 旧版：文本模型名
  textModel    String @default("deepseek-v3")
  textApiKey   String @default("")
  textBaseUrl  String @default("")

  /// 旧版：图像提供商
  imageProvider String @default("placeholder")
  imageModel    String @default("dall-e-3")
  imageApiKey   String @default("")
  imageBaseUrl  String @default("")
  comfyuiUrl    String @default("http://127.0.0.1:8188")

  /// 旧版：视频提供商
  videoProvider String @default("placeholder")
  videoModel    String @default("")
  videoApiKey   String @default("")
  videoBaseUrl  String @default("")

  /// 旧版：TTS 提供商
  ttsProvider String @default("edge-tts")
  ttsModel    String @default("")
  ttsApiKey   String @default("")
  ttsBaseUrl  String @default("")

  updatedAt DateTime @updatedAt
}
