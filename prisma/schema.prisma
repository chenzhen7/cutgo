generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  tags        String?
  coverUrl    String?

  platform    String   @default("抖音")
  aspectRatio String   @default("9:16")
  resolution  String   @default("1080x1920")
  duration    String   @default("60s")

  stylePreset     String?
  globalNegPrompt String?
  styleRefUrl     String?

  status    String   @default("draft")
  step      Int      @default(1)
  stepLabel String   @default("小说导入")

  novel    Novel?
  episodes Episode[]
  scripts  Script[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Novel {
  id        String  @id @default(cuid())
  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title     String?
  rawText   String
  wordCount Int
  source    String  @default("paste") // "paste" | "file"
  fileName  String?

  synopsis String? // AI 生成的故事大纲

  status String @default("draft") // "draft" | "analyzed" | "confirmed"

  chapters   Chapter[]
  characters NovelCharacter[]
  events     PlotEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Chapter {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  index     Int
  title     String?
  content   String
  wordCount Int
  selected  Boolean @default(true)

  paragraphs Paragraph[]
  episodes   Episode[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Paragraph {
  id        String  @id @default(cuid())
  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  index     Int
  content   String
  wordCount Int
  selected  Boolean @default(true)

  createdAt DateTime @default(now())
}

model NovelCharacter {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  name        String
  role        String  @default("supporting") // "protagonist" | "supporting" | "extra"
  description String?
  firstAppear String?
  frequency   Int     @default(1)
  relations   String? // JSON: [{ target: "角色B", relation: "恋人" }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlotEvent {
  id      String @id @default(cuid())
  novelId String
  novel   Novel  @relation(fields: [novelId], references: [id], onDelete: Cascade)

  index       Int
  type        String  // "setup" | "rising" | "climax" | "resolution"
  summary     String
  detail      String?
  emotion     String?
  sourceRef   String?
  adaptScore  Int?
  isHighlight Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Episode {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  chapterId String
  chapter   Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  index       Int
  title       String
  synopsis    String
  keyConflict String?
  cliffhanger String?
  duration    String  @default("60s")

  scenes EpisodeScene[]
  script Script?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EpisodeScene {
  id        String  @id @default(cuid())
  episodeId String
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  index      Int
  title      String
  summary    String
  duration   String  @default("15s")
  characters String?
  emotion    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Script {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  episodeId String  @unique
  episode   Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  title  String
  status String @default("draft") // "draft" | "generated" | "edited"

  scenes ScriptScene[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScriptScene {
  id       String @id @default(cuid())
  scriptId String
  script   Script @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  index       Int
  title       String
  description String?
  duration    String  @default("15s")
  emotion     String?
  bgm         String?
  location    String?

  lines ScriptLine[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScriptLine {
  id      String      @id @default(cuid())
  sceneId String
  scene   ScriptScene @relation(fields: [sceneId], references: [id], onDelete: Cascade)

  index         Int
  type          String  // "dialogue" | "narration" | "action" | "transition"
  character     String?
  emotion       String?
  content       String
  duration      String?
  parenthetical String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
